{
  "name": "nestjs-boilerplate",
  "version": "0.0.1",
  "description": "NestJS Boilerplate, Typescript, Postgres, TypeORM",
  "author": "crodic",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "env-cmd typeorm-ts-node-commonjs -d src/database/data-source.ts",
    "typeorm:create": "env-cmd typeorm-ts-node-commonjs",
    "migration:up": "pnpm typeorm migration:run",
    "migration:down": "pnpm typeorm migration:revert",
    "migration:show": "pnpm typeorm migration:show",
    "migration:create": "pnpm typeorm:create migration:create",
    "migration:generate": "pnpm typeorm migration:generate --pretty",
    "db:create": "env-cmd ts-node ./node_modules/typeorm-extension/bin/cli.cjs db:create",
    "db:drop": "env-cmd ts-node ./node_modules/typeorm-extension/bin/cli.cjs db:drop",
    "seed:run": "env-cmd ts-node ./node_modules/typeorm-extension/bin/cli.cjs seed:run",
    "seed:create": "env-cmd ts-node ./node_modules/typeorm-extension/bin/cli.cjs seed:create",
    "prepare": "husky || true",
    "docs:dev": "vuepress dev docs",
    "docs:build": "vuepress build docs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@bull-board/api": "^6.20.3",
    "@bull-board/express": "^6.20.3",
    "@bull-board/nestjs": "^6.20.3",
    "@casl/ability": "^6.8.0",
    "@keyv/redis": "^5.1.6",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.16",
    "@sentry/nestjs": "^10.42.0",
    "@slynova/flydrive": "^1.0.3",
    "@slynova/flydrive-gcs": "^1.0.3",
    "@slynova/flydrive-s3": "^1.0.3",
    "argon2": "^0.44.0",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.13.6",
    "basic-ftp": "^5.2.0",
    "bullmq": "^5.70.4",
    "cacheable": "^2.3.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "compression": "^1.8.1",
    "dotenv": "^17.3.1",
    "dropbox": "^10.34.0",
    "express-basic-auth": "^1.2.1",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "ms": "^2.1.3",
    "nestjs-cls": "^6.2.0",
    "nestjs-i18n": "^10.6.0",
    "nestjs-paginate": "^12.9.0",
    "nestjs-pino": "^4.6.0",
    "nestlens": "^0.4.0",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "qs": "^6.15.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.3",
    "ssh2-sftp-client": "^12.1.1",
    "swagger-stats": "^0.99.7",
    "tslib": "^2.8.1",
    "typeorm": "^0.3.28",
    "typeorm-extension": "^3.9.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.16",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.18",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/ms": "^2.1.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.5",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/qs": "^6.15.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.8",
    "@vuepress/bundler-vite": "2.0.0-rc.17",
    "@vuepress/plugin-markdown-image": "2.0.0-rc.52",
    "@vuepress/plugin-markdown-tab": "2.0.0-rc.52",
    "@vuepress/plugin-search": "2.0.0-rc.52",
    "@vuepress/theme-default": "2.0.0-rc.52",
    "env-cmd": "^11.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "sass-embedded": "^1.97.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vue": "^3.5.29",
    "vuepress": "2.0.0-rc.17",
    "vuepress-plugin-md-enhance": "2.0.0-rc.103"
  },
  "packageManager": "pnpm@10.30.3"
}
